        "teams:add": "ts-node src/teams/add_team.ts",
        "teams:update": "ts-node src/teams/update_team.ts",
        "teams:delete": "ts-node src/teams/delete_team.ts",
        "users:list": "ts-node src/users/list_users.ts",
        "users:view": "ts-node src/users/view_user.ts",
        "users:add": "ts-node src/users/add_user.ts",
        "users:update": "ts-node src/users/update_user.ts",
        "users:delete": "ts-node src/users/delete_user.ts",
        "link-local": "cd ../../KeeperSdk && npm link ../keeperapi && cd ../examples/sdk_example && npm link ../../keeperapi",
        "types": "tsc --watch",
        "types:ci": "tsc"
    },
    "dependencies": {
        "@keeper-security/keeperapi": "17.1.0",
        "@types/node": "^20.9.1",
        "ts-node": "^10.7.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^4.6.3"
